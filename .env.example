# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=gscc
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=gscc_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Backend (FastAPI) ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gscc:change_me_in_production@db:5432/gscc_db
DATABASE_SYNC_URL=postgresql+psycopg2://gscc:change_me_in_production@db:5432/gscc_db
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
DEBUG=true
SECRET_KEY=change_me_to_a_random_secret_in_production

# ─── Artifact storage (Docker volume mount point) ────────────────────────────
ARTIFACTS_PATH=/data/artifacts

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ─── Flower (Celery monitoring) ───────────────────────────────────────────────
FLOWER_BASIC_AUTH=admin:change_me_in_production
